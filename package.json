{
  "name": "photo-manager",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "turbo run dev --filter=@photo-manager/mobile",
    "dev:desktop": "turbo run dev --filter=@photo-manager/desktop",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "icons:generate": "node packages/desktop/scripts/generate-icons.cjs",
    "icons:audit": "node packages/desktop/scripts/audit-icons.cjs"
  },
  "overrides": {
    "react-native-gesture-handler": "2.16.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@10.9.2"
}
