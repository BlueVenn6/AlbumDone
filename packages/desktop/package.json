{
  "name": "@photo-manager/desktop",
  "version": "0.1.2-beta.7",
  "description": "AlbumDone - local-first photo manager",
  "author": "AlbumDone",
  "private": true,
  "license": "MIT",
  "main": "dist/main/index.js",
  "build": {
    "appId": "com.albumdone.app",
    "productName": "AlbumDone",
    "copyright": "Copyright © 2026 AlbumDone",
    "electronVersion": "41.7.1",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!node_modules/@photo-manager/shared/.turbo/**/*",
      "!node_modules/@photo-manager/shared/public/**/*",
      "!node_modules/@photo-manager/shared/scripts/**/*",
      "!node_modules/@photo-manager/shared/src/**/*",
      "!node_modules/@photo-manager/shared/tests/**/*",
      "!node_modules/@photo-manager/shared/tsconfig.json"
    ],
    "extraResources": [
      {
        "from": "chi_sim.traineddata",
        "to": "chi_sim.traineddata"
      },
      {
        "from": "eng.traineddata",
        "to": "eng.traineddata"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/keytar/**",
      "**/node_modules/canvas/**",
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${env.ALBUMDONE_BUILD_ID}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AlbumDone"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc --watch --project tsconfig.json --outDir dist",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on http://localhost:5173 dist/main/index.js && cross-env NODE_ENV=development node scripts/start-electron.cjs",
    "clean:package": "node scripts/clean-package.cjs",
    "build:shared": "npm --prefix ../.. --workspace @photo-manager/shared run build",
    "build": "npm run build:shared && npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.json --outDir dist",
    "build:renderer": "vite build --config vite.config.ts",
    "electron": "cross-env NODE_ENV=development node scripts/start-electron.cjs",
    "typecheck": "npm run build:shared && tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "npm run build:main && node tests/asyncTimeout.test.cjs && node tests/resilientVisualHashBatch.test.cjs && node tests/yearInReviewMonthPlan.test.cjs && node tests/yearInReviewExport.test.cjs && node tests/yearInReviewIpcContract.test.cjs",
    "pretest:e2e": "electron-builder install-app-deps",
    "test:e2e": "node tests/electron.production.e2e.cjs",
    "benchmark:reproducible": "node scripts/benchmark-reproducible.cjs",
    "validate:visual-hashes": "npm run build:main && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/validate-visual-hash-library.cjs",
    "package": "node scripts/package-desktop.cjs",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.82",
    "@photo-manager/shared": "*",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.1.0",
    "express": "^4.22.2",
    "i18next": "^23.16.8",
    "immer": "^10.2.0",
    "keytar": "^7.9.0",
    "path-to-regexp": "0.1.13",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-i18next": "^14.1.3",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "ws": "^8.21.1",
    "zustand": "^4.5.7"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.1",
    "png-to-ico": "^2.1.8",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "typescript": "^5.4.0",
    "vite": "^8.1.5",
    "wait-on": "^9.0.10"
  }
}
