{
  "name": "@photo-manager/mobile",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "react-native start",
    "web": "vite --config vite.config.ts --host 127.0.0.1",
    "web:build": "vite build --config vite.config.ts",
    "web:preview": "vite preview --config vite.config.ts --host 127.0.0.1",
    "android": "npm run ensure:native:android && react-native run-android",
    "ios": "npm run ensure:native:ios && react-native run-ios",
    "build": "tsc --project tsconfig.json --outDir dist",
    "build:android": "npm run ensure:native:android && react-native build-android --mode=release",
    "build:ios": "npm run ensure:native:ios && react-native build-ios --mode=release",
    "ensure:native:android": "node ./scripts/check-native-project.js android",
    "ensure:native:ios": "node ./scripts/check-native-project.js ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "npm run build && node tests/albumCounts.test.cjs && node tests/photoScannerPagination.test.cjs && node tests/yearReviewLayout.test.cjs && node tests/nativeBridgeParity.test.cjs && node tests/mobileEndpointPolicy.test.cjs && node tests/mobileBootstrap.test.cjs && node tests/modelConfigParity.test.cjs"
  },
  "dependencies": {
    "@photo-manager/shared": "*",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@react-navigation/stack": "^6.3.0",
    "@babel/runtime": "^7.20.0",
    "i18next": "^23.11.0",
    "react": "18.2.0",
    "react-i18next": "^14.1.0",
    "react-native": "0.74.0",
    "react-native-gesture-handler": "2.16.2",
    "react-native-keychain": "^10.0.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "^3.31.0",
    "react-native-view-shot": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@react-native/babel-preset": "0.74.0",
    "@react-native/eslint-config": "0.74.0",
    "@react-native/metro-config": "0.74.0",
    "@react-native/typescript-config": "0.74.0",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react-dom": "^18.2.0",
    "react-native-web": "^0.19.12",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
